<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
  <title>Pure Counter • Crash Test</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      user-select: none;
    }

    body {
      background: white;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', monospace;
      padding: 20px;
    }

    /* Absolutely minimal: just a big number */
    .counter-screen {
      text-align: center;
      width: 100%;
    }

    .big-number {
      font-size: min(28vw, 180px);
      font-weight: 800;
      font-family: 'Inter', 'Segoe UI', monospace;
      letter-spacing: -0.02em;
      color: #111111;
      line-height: 1.1;
      transition: all 0.02s linear;
    }

    /* optional micro status dot for connection (tiny, subtle) */
    .conn-dot {
      position: fixed;
      bottom: 14px;
      right: 14px;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #22c55e;
      opacity: 0.7;
      transition: background 0.2s;
    }
  </style>
</head>
<body>

<div class="counter-screen">
  <div class="big-number" id="counterNumber">1.00</div>
</div>
<div class="conn-dot" id="connDot"></div>

<script type="module">
  // --------------------------------------------------------------
  // PURE COUNTER – reads crash points from Firebase queue
  // - Counts up from 1.00 to the crash point (e.g., 2.21, 5.40, 93.31)
  // - No "crash" text, no "flew away", no upcoming queue, no history, no graph
  // - Only the number counts up and then resets to next round (countdown hidden)
  // - White background, minimal style
  // --------------------------------------------------------------
  
  const FIREBASE_CONFIG = {
    apiKey:            "AIzaSyBfGx3mLuZ85b_JkRUJXwloLJXNT3uyn7M",
    authDomain:        "aviator-23914.firebaseapp.com",
    projectId:         "aviator-23914",
    storageBucket:     "aviator-23914.firebasestorage.app",
    messagingSenderId: "139941060687",
    appId:             "1:139941060687:web:c20f9bafa9d8d3aacf4a3a",
    measurementId:     "G-031VMZEKHE"
  };
  
  import { initializeApp } from 'https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js';
  import { getFirestore, doc, onSnapshot } from 'https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js';
  
  const app = initializeApp(FIREBASE_CONFIG);
  const db  = getFirestore(app);
  
  // DOM element
  const counterNumberEl = document.getElementById('counterNumber');
  const connDot = document.getElementById('connDot');
  
  // ------------------- STATE -------------------
  let activeRoundId    = '';        // current round ID from Firebase
  let targetCrash      = 2.0;       // multiplier we need to count up to (e.g., 2.21)
  let isCounting       = false;     // actively counting up
  let hasCrashedFlag   = false;     // internal flag to avoid double triggers
  let currentMult      = 1.00;
  let roundStartTime   = 0;
  let animationId      = null;
  let crashTimeout     = null;
  let bettingTimeout   = null;
  let resetTimer       = null;
  
  // RATE constant – matches original smooth exponential growth: multiplier = exp(RATE * time)
  const RATE_CONST = 0.085;
  
  // helper: cancel all timers/animations
  function cancelAll() {
    if (animationId) {
      cancelAnimationFrame(animationId);
      animationId = null;
    }
    if (crashTimeout) {
      clearTimeout(crashTimeout);
      crashTimeout = null;
    }
    if (bettingTimeout) {
      clearTimeout(bettingTimeout);
      bettingTimeout = null;
    }
    if (resetTimer) {
      clearTimeout(resetTimer);
      resetTimer = null;
    }
  }
  
  // stop counting and reset to idle (no visible countdown, just number stays at 1.00 until next round)
  function resetToIdle() {
    cancelAll();
    isCounting = false;
    hasCrashedFlag = false;
    currentMult = 1.00;
    // set number to 1.00 (idle state)
    counterNumberEl.innerText = '1.00';
  }
  
  // start counting from 1.00 up to crashPoint, starting at 'startTimestamp'
  function startCounting(crashPoint, startTimestamp) {
    // kill any ongoing animation and timers
    cancelAll();
    
    isCounting = true;
    hasCrashedFlag = false;
    targetCrash = crashPoint;
    roundStartTime = startTimestamp || Date.now();
    currentMult = 1.00;
    counterNumberEl.innerText = '1.00';
    
    // calculate total duration to reach crash point: crash = exp(RATE * totalSec) => totalSec = ln(crash)/RATE
    const totalDurationMs = (Math.log(targetCrash) / RATE_CONST) * 1000;
    const elapsedAlready = Math.max(0, Date.now() - roundStartTime);
    let remainingMs = totalDurationMs - elapsedAlready;
    if (remainingMs < 5) remainingMs = 5;
    
    // schedule crash moment (after that, number will jump back to 1.00 after a short pause)
    crashTimeout = setTimeout(() => {
      if (isCounting && !hasCrashedFlag) {
        // crash occurred: counting stops, number will reset after 1.2 seconds (no crash message)
        isCounting = false;
        hasCrashedFlag = true;
        if (animationId) cancelAnimationFrame(animationId);
        animationId = null;
        
        // keep final crash number displayed for a moment, then reset to 1.00 (clean)
        // we do NOT show "crash" text or any extra UI, just the number stays at crash value briefly
        const finalValue = targetCrash.toFixed(2);
        counterNumberEl.innerText = finalValue;
        
        // after 1.2 seconds reset to idle (1.00) – no extra messages
        resetTimer = setTimeout(() => {
          resetToIdle();
          // after reset, we rely on Firestore to trigger next betting window / round start
        }, 1200);
      }
    }, remainingMs);
    
    // start animation frame for smooth counting
    function updateCounter() {
      if (!isCounting || hasCrashedFlag) {
        if (animationId) cancelAnimationFrame(animationId);
        return;
      }
      const now = Date.now();
      const elapsedSec = (now - roundStartTime) / 1000;
      let mult = Math.exp(RATE_CONST * elapsedSec);
      // clamp to target crash (never exceed visually)
      if (mult >= targetCrash) {
        mult = targetCrash;
        if (!hasCrashedFlag && isCounting) {
          // if we reached the target but crash timeout didn't fire instantly, trigger crash manually
          if (crashTimeout) clearTimeout(crashTimeout);
          isCounting = false;
          hasCrashedFlag = true;
          counterNumberEl.innerText = mult.toFixed(2);
          if (animationId) cancelAnimationFrame(animationId);
          animationId = null;
          resetTimer = setTimeout(() => {
            resetToIdle();
          }, 1200);
          return;
        }
      }
      currentMult = mult;
      counterNumberEl.innerText = currentMult.toFixed(2);
      animationId = requestAnimationFrame(updateCounter);
    }
    
    animationId = requestAnimationFrame(updateCounter);
  }
  
  // ----- Process Firestore queue document -----
  function handleQueueUpdate(data) {
    if (!data) return;
    
    const roundId      = data.roundId || '';
    const crashAt      = data.crashAt || 2.0;
    const bettingStart = data.bettingStart || Date.now();
    const roundStart   = data.roundStart || 0;
    
    // NEW ROUND: roundId changed
    if (roundId !== activeRoundId) {
      activeRoundId = roundId;
      
      // cancel everything: we are switching to a new round cycle
      cancelAll();
      isCounting = false;
      hasCrashedFlag = false;
      
      // check if round already started (roundStart > 0)
      if (roundStart > 0 && roundStart <= Date.now()) {
        // round already in progress – join mid-flight
        startCounting(crashAt, roundStart);
      } else {
        // betting window active: we need to wait until betting window ends, then start counting
        const now = Date.now();
        let bettingRemaining = (bettingStart + 7000) - now;
        if (bettingRemaining < 0) bettingRemaining = 0;
        
        if (bettingRemaining <= 50) {
          // almost zero or negative: start immediately
          startCounting(crashAt, Date.now());
        } else {
          // show idle (number stays at 1.00) until betting window ends
          counterNumberEl.innerText = '1.00';
          isCounting = false;
          if (bettingTimeout) clearTimeout(bettingTimeout);
          bettingTimeout = setTimeout(() => {
            if (activeRoundId === roundId) {
              startCounting(crashAt, Date.now());
            }
          }, bettingRemaining);
        }
      }
    } 
    else if (roundId === activeRoundId && roundStart > 0 && !isCounting && !hasCrashedFlag && !bettingTimeout) {
      // same round, but roundStart just got written (late start) and we are idle
      if (roundStart <= Date.now()) {
        startCounting(crashAt, roundStart);
      }
    }
    
    // update connection dot color (just visual feedback)
    connDot.style.backgroundColor = '#22c55e';
    connDot.style.opacity = '0.9';
  }
  
  // start Firebase listener
  let unsubQueue = null;
  function initFirebaseListener() {
    if (unsubQueue) unsubQueue();
    const queueRef = doc(db, 'gameRounds', 'queue');
    unsubQueue = onSnapshot(queueRef, 
      (snap) => {
        if (!snap.exists()) {
          // no document yet: keep number at 1.00, dot = amber
          connDot.style.backgroundColor = '#eab308';
          connDot.style.opacity = '0.6';
          counterNumberEl.innerText = '1.00';
          return;
        }
        const data = snap.data();
        handleQueueUpdate(data);
      },
      (error) => {
        console.warn('Firestore error:', error);
        connDot.style.backgroundColor = '#ef4444';
        connDot.style.opacity = '0.7';
      }
    );
  }
  
  // reset UI to 1.00 on start, white background
  counterNumberEl.innerText = '1.00';
  initFirebaseListener();
  
  // optional: if page is hidden, cancel animations to save resources
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      if (animationId) cancelAnimationFrame(animationId);
      animationId = null;
    } else {
      // if we were counting but animation stopped, restart? we rely on frame request
      if (isCounting && !hasCrashedFlag && !animationId) {
        function restartAnim() {
          if (!isCounting || hasCrashedFlag) return;
          const now = Date.now();
          const elapsedSec = (now - roundStartTime) / 1000;
          let mult = Math.exp(RATE_CONST * elapsedSec);
          if (mult >= targetCrash) mult = targetCrash;
          currentMult = mult;
          counterNumberEl.innerText = currentMult.toFixed(2);
          animationId = requestAnimationFrame(restartAnim);
        }
        animationId = requestAnimationFrame(restartAnim);
      }
    }
  });
  
  // clean up on page unload
  window.addEventListener('beforeunload', () => {
    if (unsubQueue) unsubQueue();
    cancelAll();
  });
</script>
</body>
</html>
